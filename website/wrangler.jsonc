{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dayline-website",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "preview_urls": true,
  "routes": [
    {
      "pattern": "dayline.robin.build",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
